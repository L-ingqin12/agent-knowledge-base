#!/bin/bash
# ============================================================================
# 代理变更管控门禁 — pre-commit 钩子
# 防止提交 claude-resilience-proxy.js 变更时未提及 deploy 工作流
#
# 允许绕过: git commit --no-verify
# ============================================================================
set -e

RED='\033[0;31m'; YELLOW='\033[1;33m'; NC='\033[0m'
err() { echo -e "${RED}[gate]${NC} $1"; }

# ── 检查 proxy.js 是否在暂存区 ────────────────────────────────────────

staged_files=$(git diff --cached --name-only 2>/dev/null || true)

# 使用临时关闭 set -e 的方式安全检查 grep 返回值
match=0
echo "$staged_files" | grep -q 'claude-resilience-proxy.js' && match=1

if [ "$match" -eq 0 ]; then
  exit 0  # 未涉及 proxy.js, 门禁放行
fi

# ── proxy.js 已暂存 — 检查提交信息 ────────────────────────────────────

GIT_DIR=$(git rev-parse --git-dir 2>/dev/null)
COMMIT_MSG_FILE="$GIT_DIR/COMMIT_EDITMSG"

if [ -f "$COMMIT_MSG_FILE" ] && [ -s "$COMMIT_MSG_FILE" ]; then
  commit_msg=$(cat "$COMMIT_MSG_FILE")
  ref_match=0
  echo "$commit_msg" | grep -qiE 'proxy|deploy|gate' && ref_match=1
  if [ "$ref_match" -eq 1 ]; then
    exit 0
  fi
fi

# ── 未通过 — 输出错误并中止 ───────────────────────────────────────────

echo ""
err "proxy.js 已暂存, 但提交信息未提及 proxy/deploy/gate"
err ""
err "请使用符合门禁要求的提交信息, 例如:"
err "  git commit -m \"feat: proxy 超时修复...\""
err "  git commit -m \"fix(proxy): 修复连接关闭竞态...\""
err "  git commit -m \"deploy: 升级代理到 v2.1...\""
err ""
err "如需绕过 (仅限紧急情况):"
err "  git commit --no-verify"

# ── 检查禁止模式 (诊断代码残留) ───────────────────────────────────────

# 检查暂存的 proxy.js 中是否包含诊断/调试代码
diag_found=0
git diff --cached -- claude-resilience-proxy.js 2>/dev/null | grep '^+' | grep -qE 'clientReq\.on.*close|clientClosed' && diag_found=1
if [ "$diag_found" -eq 1 ]; then
  echo ""
  err "检测到诊断代码残留: clientReq.on.*close / clientClosed"
  err "请移除调试代码后重新提交"
fi

exit 1
